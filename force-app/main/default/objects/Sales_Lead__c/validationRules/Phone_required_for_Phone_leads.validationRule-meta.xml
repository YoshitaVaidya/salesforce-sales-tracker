<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Phone_required_for_Phone_leads</fullName>
    <active>true</active>
    <description>Ensures Phone is captured for Phone lead sources</description>
    <errorConditionFormula>ISPICKVAL( Source__c , &quot;Phone&quot;)  &amp;&amp;  ISBLANK( Phone__c )</errorConditionFormula>
    <errorDisplayField>Phone__c</errorDisplayField>
    <errorMessage>Phone is required for Phone leads</errorMessage>
</ValidationRule>
