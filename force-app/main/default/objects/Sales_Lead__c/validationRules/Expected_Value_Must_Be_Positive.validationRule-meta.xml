<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Expected_Value_Must_Be_Positive</fullName>
    <active>true</active>
    <errorConditionFormula>Expected_Value__c  &lt;= 0</errorConditionFormula>
    <errorDisplayField>Expected_Value__c</errorDisplayField>
    <errorMessage>Expected Value must be greater than zero.</errorMessage>
</ValidationRule>
