<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <description>Assigns High priority to leads with score &gt;= 70.</description>
        <name>Assign_High_Priority</name>
        <label>Assign High Priority</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Lead_Priority__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>High</stringValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Assign_Lead_Score</name>
        <label>Assign Lead Score</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Lead_Score__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Total_Lead_Score_Formula</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Check_Lead_Priority</targetReference>
        </connector>
    </assignments>
    <assignments>
        <description>Assigns Low priority to leads with score below 40.</description>
        <name>Assign_Low_Priority</name>
        <label>Assign Low Priority</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Lead_Priority__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Low</stringValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <description>Assigns Medium priority to leads with score between 40 and 69.</description>
        <name>Assign_Medium_Priority</name>
        <label>Assign Medium Priority</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.Lead_Priority__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Medium</stringValue>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <description>Determines lead priority (High, Medium, Low) based on calculated Lead Score.</description>
        <name>Check_Lead_Priority</name>
        <label>Check Lead Priority</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_Low_Priority</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Low Priority</defaultConnectorLabel>
        <rules>
            <name>High_Priority</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Lead_Score__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>70.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_High_Priority</targetReference>
            </connector>
            <label>High Priority</label>
        </rules>
        <rules>
            <name>Medium_Priority</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Lead_Score__c</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>40.0</numberValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Lead_Score__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <numberValue>70.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Medium_Priority</targetReference>
            </connector>
            <label>Medium Priority</label>
        </rules>
    </decisions>
    <decisions>
        <description>Lead Score should get freeze when Lead Qualified</description>
        <name>Freeze_Score</name>
        <label>Freeze Score?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_Lead_Score</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Calculate Score</defaultConnectorLabel>
        <rules>
            <name>Freeze</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>New</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>NotEqualTo</operator>
                <rightValue>
                    <stringValue>Working</stringValue>
                </rightValue>
            </conditions>
            <label>Freeze</label>
        </rules>
    </decisions>
    <description>Added Lead Priority assignment logic based on Lead Score</description>
    <environments>Default</environments>
    <formulas>
        <name>ExpectedValue_Score_Formula</name>
        <dataType>Number</dataType>
        <expression>IF(ISBLANK($Record.Expected_Value__c), 0.0,
IF($Record.Expected_Value__c &gt; 100000, 30.0,
IF($Record.Expected_Value__c &gt;= 50000, 20.0, 10.0)))</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>Source_Score_Formula</name>
        <dataType>Number</dataType>
        <expression>CASE(TEXT($Record.Source__c),
     &quot;Website&quot;, 10.0,
     &quot;Phone&quot;, 20.0,
     &quot;Email&quot;, 15.0,
     &quot;Referral&quot;, 25.0,
     &quot;Social Media&quot;, 12.0,
     0.0)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>Status_Score_Formula</name>
        <dataType>Number</dataType>
        <expression>IF(TEXT($Record.Status__c) = &quot;New&quot;, 10.0,
IF(TEXT($Record.Status__c )= &quot;Working&quot;, 30.0, 0.0))</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>Total_Lead_Score_Formula</name>
        <dataType>Number</dataType>
        <expression>{!Status_Score_Formula} + {!Source_Score_Formula} + {!ExpectedValue_Score_Formula}</expression>
        <scale>0</scale>
    </formulas>
    <interviewLabel>Sales Lead – Calculate Lead Score (Before Save) {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Sales Lead – Calculate Lead Score (Before Save)</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Freeze_Score</targetReference>
        </connector>
        <object>Sales_Lead__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
